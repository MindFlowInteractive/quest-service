# Auto-detect text files
*               text=auto eol=lf

# Source code
*.ts            text eol=lf
*.js            text eol=lf
*.json          text eol=lf
*.yml           text eol=lf
*.yaml          text eol=lf
*.md            text eol=lf

# Shell scripts
*.sh            text eol=lf

# Windows-friendly batch files
*.bat           text eol=crlf

# Binary files
*.png           binary
*.jpg           binary
*.jpeg          binary
*.gif           binary
*.ico           binary
*.pdf           binary
*.woff          binary
*.woff2         binary

# Prevent merge conflicts on lock files (generated)
package-lock.json -diff
yarn.lock       -diff
pnpm-lock.yaml  -diff
