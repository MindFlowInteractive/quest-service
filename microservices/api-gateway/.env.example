# API Gateway Environment Configuration

# Server Configuration
PORT=3000
NODE_ENV=development

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRES_IN=1h

# Rate Limiting
RATE_LIMIT_TTL=60
RATE_LIMIT_MAX=100
RATE_LIMIT_MAX_AUTHENTICATED=200

# Circuit Breaker
CIRCUIT_BREAKER_TIMEOUT=5000
CIRCUIT_BREAKER_ERROR_THRESHOLD=50
CIRCUIT_BREAKER_RESET_TIMEOUT=30000
CIRCUIT_BREAKER_MIN_REQUESTS=10

# CORS
CORS_ORIGINS=http://localhost:3000,http://localhost:3001,https://yourdomain.com

# Logging
LOG_LEVEL=info
LOG_FILE_ENABLED=true

# Health Check
HEALTH_CHECK_INTERVAL=30000

# Service URLs (Core Services)
SOCIAL_SERVICE_URL=http://localhost:3001
QUEST_SERVICE_URL=http://localhost:3002

# Service URLs (Game Services)
ACHIEVEMENT_SERVICE_URL=http://localhost:3003
GAME_SESSION_SERVICE_URL=http://localhost:3004
PUZZLE_SERVICE_URL=http://localhost:3005

# Service URLs (Content Services)
CONTENT_SERVICE_URL=http://localhost:3006

# Service URLs (Economy Services)
ECONOMY_SERVICE_URL=http://localhost:3007
REWARD_SERVICE_URL=http://localhost:3008

# Service URLs (Communication Services)
NOTIFICATION_SERVICE_URL=http://localhost:3009
EMAIL_SERVICE_URL=http://localhost:3010

# Service URLs (Tournament Services)
TOURNAMENT_SERVICE_URL=http://localhost:3011
MATCHMAKING_SERVICE_URL=http://localhost:3012

# Service URLs (Analytics Services)
ANALYTICS_SERVICE_URL=http://localhost:3013
RECOMMENDATION_SERVICE_URL=http://localhost:3014

# Service URLs (Infrastructure Services)
CACHE_SERVICE_URL=http://localhost:3015
WEBSOCKET_SERVICE_URL=http://localhost:3016
MODERATION_SERVICE_URL=http://localhost:3017
REPLAY_SERVICE_URL=http://localhost:3018

# Security Headers
HELMET_ENABLED=true
XSS_PROTECTION=true
NOSNIFF=true

# Request Timeout (in milliseconds)
REQUEST_TIMEOUT=30000

# Service Discovery
SERVICE_DISCOVERY_ENABLED=false
CONSUL_HOST=localhost
CONSUL_PORT=8500

# Metrics and Monitoring
METRICS_ENABLED=false
PROMETHEUS_PORT=9090

# SSL/TLS Configuration (for production)
SSL_ENABLED=false
SSL_CERT_PATH=
SSL_KEY_PATH=

# Redis Configuration (for rate limiting and caching)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# Database Configuration (if needed for gateway-specific data)
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=password
DB_NAME=api_gateway
